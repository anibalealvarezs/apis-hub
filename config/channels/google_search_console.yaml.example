channels:
  google_search_console:
    enabled: true
    cache_all: false # If true, will fetch all accessible sites if none are listed below
    cache_include: null # Optional. Text or PCRE Regex to include sites by URL or Title
    cache_exclude: null # Optional. Text or PCRE Regex to exclude sites
    scope: 'https://www.googleapis.com/auth/webmasters'
    token: '${GOOGLE_SEARCH_CONSOLE_TOKEN}'
    sites:
      - url: 'sc-domain:example.com'
        title: 'Example Site'
        hostname: example.com
        include_keywords: []
        exclude_keywords: []
        include_countries: []
        exclude_countries: []
        include_pages: []
        exclude_pages: []
        target_countries: []
        target_keywords: []
        enabled: true
    metrics_cache_ttl: 86400
