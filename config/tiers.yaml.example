# Worker Tier Resource Definitions
# Defines standardized resource allocations for different workload levels.
#
# Tiers:
#   0: Reservation
#   1: Minimal
#   2: Standard Worker (Basic)
#   3: Medium Worker (e.g., GSC with synthetics)
#   4: Large Worker (e.g., Heavy data processing)
#   4: Exceptional Worker (e.g., Ultra-heavy data processing)

tiers:
  0:
    memory: '128M'
    cpu: '0.30'
  1:
    memory: '256M'
    cpu: '0.30'
  2:
    memory: '384M'
    cpu: '0.50'
  3:
    memory: '512M'
    cpu: '0.50'
  4:
    memory: '1024M'
    cpu: '1.00'
  5:
    memory: '2048M'
    cpu: '1.50'
