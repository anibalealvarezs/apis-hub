database:
  testing:
    driver: ${DB_DRIVER:-pdo_mysql}
    host: '${DB_HOST:-127.0.0.1}'
    port: ${DB_PORT:-3306}
    user: ${DB_USER:-root}
    password: '${DB_PASSWORD:-YOUR_PASSWORD}'
    name: '${DB_NAME:-apis-hub-testing}'
  production:
    driver: ${DB_DRIVER:-pdo_mysql}
    host: '${DB_HOST:-db}'
    port: ${DB_PORT:-3306}
    user: ${DB_USER}
    password: ${DB_PASSWORD}
    name: ${DB_NAME}
