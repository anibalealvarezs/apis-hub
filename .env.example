# apis-hub Environment Configuration
# Copy this to .env and adjust as needed

# Environment (testing or production)
APP_ENV=testing

# --- Infrastructure vs Project Configuration ---
# PROJECT_NAME: Logical name used for display and non-critical labelling
PROJECT_NAME=apis-hub-example
# DEPLOYMENT_NAME: Infrastructure ID used for volumes and container grouping.
# ⚠️ WARNING: DO NOT modify DEPLOYMENT_NAME after initial deployment, 
# as Docker will create new empty volumes and you will lose data persistence.
DEPLOYMENT_NAME=apis-hub
# -----------------------------------------------

# Database Configuration (Overrides config/database.yaml)
DB_DRIVER=pdo_mysql
# Use 'host.docker.internal' for host-based MySQL (Laragon)
# Use 'db' to spin up a dedicated MySQL container
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=NoEntiendo2321
DB_NAME=apis-hub-17

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
APP_API_KEY=your-secret-key-here
APP_TIMEZONE=UTC
# Authorized IPs must be a JSON array: ["127.0.0.1", "1.2.3.4"]
AUTHORIZED_IPS=[]

# CLI Configuration
CLI_MEMORY_LIMIT=1G

# Facebook Credentials
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_USER_TOKEN=
FACEBOOK_USER_ID=
FACEBOOK_REDIRECT_URI=
FACEBOOK_TOKEN_PATH=
FACEBOOK_ACCOUNTS_GROUP=

# Google Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_REDIRECT_URI=
GOOGLE_USER_ID=
GOOGLE_TOKEN_PATH=

# Google Search Console Credentials
GOOGLE_SEARCH_CONSOLE_CLIENT_ID=
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=
GOOGLE_SEARCH_CONSOLE_REFRESH_TOKEN=
GOOGLE_SEARCH_CONSOLE_TOKEN=
# (GSC_TOKEN is managed automatically in storage/tokens/google_tokens.json if not specified)
