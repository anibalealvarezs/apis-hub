# ─────────────────────────────────────────────────────────────────────────────
# apis-hub · Project deployment configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to deploy/project.yaml to start your local project configuration.
# Fill in real values and run your application.
#
# This file supports environment variable interpolation using the following syntax:
#   ${VAR_NAME:-default_value}
#
# This allows you to have a single configuration file that works both locally
# and in a Dockerized environment.
# ─────────────────────────────────────────────────────────────────────────────

# used as Docker image/container prefix (e.g. alimentos-bahia)
project: my-project

# ── Database ─────────────────────────────────────────────────────────────────
# The application uses APP_ENV to switch between 'testing' and 'production'.
# Defaults to 'testing' if APP_ENV is not set.
database:
  # Configuration for local development and test execution
  testing:
    driver: pdo_mysql
    host: ${DB_HOST:-host.docker.internal}
    port: 3306
    user: root
    password: YOUR_LOCAL_PASSWORD
    name: ${DB_NAME:-apis-hub-testing}

  # Configuration for production (e.g. Docker container networking)
  production:
    driver: pdo_mysql
    host: ${PROD_DB_HOST:-host.docker.internal}
    port: 3306
    user: root
    password: ${PROD_DB_PASSWORD:-YOUR_PROD_PASSWORD}
    name: ${PROD_DB_NAME:-apis-hub-production}

# ── Redis ────────────────────────────────────────────────────────────────────
redis:
  # Redis host (use 'redis' if running in Docker stack, or 127.0.0.1 for local)
  host: ${REDIS_HOST:-127.0.0.1}
  # Redis port (default 6379)
  port: ${REDIS_PORT:-6379}

# ── Worker instances (Scheduled Caching) ──────────────────────────────────────
# Each entry defines a worker container/process for a specific channel and entity.
# - channel: must match a Channel enum value (gsc, facebook, klaviyo, shopify, etc.)
# - entity: analytics entity to fetch/cache (metric, query, channeled_campaign, etc.)
# - frequency: (Optional) Cron expression. If running in Docker, this sets the automation frequency.
# - start_date / end_date: (Optional) ISO dates ("2024-01-01") OR relative keywords:
#     "today", "yesterday", "-N days", "-1 week", "first day of this month", etc.
instances:
  - name: gsc-daily-metrics
    frequency: "0 4 * * *" # Runs daily at 04:00 AM
    channel: gsc
    entity: metric
    # GOLD STANDARD: -3 days to yesterday for reliable attribution
    start_date: "-3 days"
    end_date: "yesterday"
    # Granularity: 1 day (standard for aggregated metrics)

  - name: fb-ads-daily
    frequency: "0 5 * * *" # Runs daily at 05:00 AM
    channel: facebook
    entity: metric
    # GOLD STANDARD: -3 days to yesterday for reliable attribution
    start_date: "-3 days"
    end_date: "yesterday"
    # Granularity: 1 day (standard for aggregated metrics)

# ── Channel credentials & config ─────────────────────────────────────────────
# Credentials and specific settings for each integration channel.
# Only populate the channels you actually use; disabled ones will be ignored.
channels:
  # Google OAuth Main Configuration (Base for GSC, Analytics, etc.)
  google:
    enabled: false                         # Set to true to enable Google-related services
    client_id: ${GOOGLE_CLIENT_ID:-YOUR_CLIENT_ID} # Google Cloud Client ID
    client_secret: ${GOOGLE_CLIENT_SECRET:-YOUR_CLIENT_SECRET} # Google Cloud Client Secret
    # Usually https://oauth.pstmn.io/v1/browser-callback for development
    redirect_uri: ${GOOGLE_REDIRECT_URI:-https://oauth.pstmn.io/v1/browser-callback}
    refresh_token: ${GOOGLE_REFRESH_TOKEN:-YOUR_REFRESH_TOKEN} # Persistent refresh token
    user_id: ${GOOGLE_USER_EMAIL:-you@example.com} # Main email associated with the credentials
    # Path to store/read tokens persistently
    token_path: ./config/google_tokens.json
    # Scopes needed across all google services in this deployment
    scopes:
      - https://www.googleapis.com/auth/webmasters

  # Google Search Console specific settings
  google_search_console:
    enabled: false                         # Set to true to enable GSC sync
    scope: https://www.googleapis.com/auth/webmasters
    # sites: List of properties you want to track
    sites:
      - url: "sc-domain:yourdomain.com"     # property URL or sc-domain: format for domain properties
        title: "Your Site Name"             # Friendly name for the site
        hostname: "yourdomain.com"          # The base domain name
        enabled: true                       # Set to false to skip this specific site
        # Advanced Filtering
        include_keywords: []                # Process ONLY these keywords (leave empty for all)
        exclude_keywords: ["internal", "staging"] # Skip these keywords
        include_countries: []               # Process ONLY these countries (3-letter codes)
        exclude_countries: []               # Skip these countries
        include_pages: []                   # Process ONLY these URL paths
        exclude_pages: ["/admin/", "/?s=", ".phtml"] # Exclude patterns/extensions
        # Target metadata for specific reporting
        target_countries: ["usa", "esp"]    # Primary countries for focused reporting
        target_keywords: ["brand", "seo"]   # Strategic keywords for focused reporting
    # Time to live for metrics cache in seconds (e.g. 86400 = 24h)
    metrics_cache_ttl: 86400

  # Facebook Marketing & Graph API settings (Meta)
  facebook:
    enabled: false                         # Set to true to enable Facebook/Instagram sync
    app_id: ${FB_APP_ID:-YOUR_APP_ID}       # Meta App ID
    app_secret: ${FB_APP_SECRET:-YOUR_APP_SECRET} # Meta App Secret
    app_redirect_uri: ${FB_REDIRECT_URI:-YOUR_REDIRECT_URI}
    user_id: ${FB_USER_ID:-YOUR_USER_ID}   # Numerical Facebook User ID
    accounts_group_name: "Project/Client Name" # Label for grouping accounts in database
    # Tokens (Graph API)
    # Temporary user access token from Graph API Explorer (usually 1 hour).
    # IMPORTANT: If using this, run the app immediately so it can be exchanged for a long-lived token.
    graph_user_access_token: ${FB_USER_TOKEN}
    graph_page_access_token: ${FB_PAGE_TOKEN} # Page-specific access token
    # Optional: If you already have a 60-day token, paste it here.
    # This will override the short-lived user token and be stored in the JSON cache.
    graph_long_lived_user_access_token: ${FB_LONG_LIVED_USER_TOKEN} # Highly recommended for background workers
    graph_long_lived_page_access_token: ${FB_LONG_LIVED_PAGE_TOKEN} # Highly recommended for background workers
    # Path to store/read tokens persistently (ensures long-lived tokens survive restarts)
    graph_token_path: ./config/facebook_tokens.json
    
    # Facebook Pages to track (includes Instagram settings)
    pages:
      - id: 12345678                          # Numerical Facebook Page ID
        url: https://www.facebook.com/yourpage # Canonical URL of the page
        title: Your Page                      # Friendly name
        hostname: yourdomain.com             # Base domain for cross-referencing
        enabled: true                        # Set to false to skip this page
        # Sync Toggles (Organic Data)
        page_metrics: true                   # Fetch Page-level insights (reach, views, etc.)
        posts: true                          # Sync post metadata (captions, images)
        post_metrics: true                   # Fetch engagement for each post (likes, comments)
        # Instagram Integration
        ig_account: 178414...                 # Instagram Business ID
        ig_account_metrics: true             # Fetch IG account-level insights
        ig_account_media: true               # Sync IG media (stories, reels, posts)
        ig_account_media_metrics: true       # Fetch engagement for IG media
        ig_account_media_stop_id: null        # Performance: skip sync older than this media ID

    # Ad Accounts to track
    ad_accounts:
      - id: 338111...                         # Numerical Ad Account ID
        enabled: true                        # Set to false to skip this account
        # Sync Toggles (Paid Data)
        ad_account_metrics: true             # Fetch account-level spend/results
        campaigns: true                      # Sync Campaign entities
        campaign_metrics: true               # Fetch metrics at Campaign level
        adsets: true                         # Sync AdSet entities
        adset_metrics: true                  # Fetch metrics at AdSet level
        ads: true                            # Sync Ad entities
        ad_metrics: true                     # Fetch metrics at Ad level
        creatives: true                      # Sync Ad Creatives (images/videos/text)
        creative_metrics: true               # Fetch performance per creative

  # Klaviyo API settings (Email & SMS Marketing)
  klaviyo:
    enabled: false                         # Set to true to enable Klaviyo sync
    klaviyo_api_key: KLAVIYO_API_KEY       # Private API Key
    # Metrics names as they appear in Klaviyo
    metrics:
      - Added to Cart                        # Name of the event as defined in Klaviyo
      - Placed Order                         # Name of the event as defined in Klaviyo
    metrics_cache_ttl: 86400

  # Shopify API settings (E-commerce)
  shopify:
    enabled: false                         # Set to true to enable Shopify sync
    shopify_api_key: SHOPIFY_API_KEY       # Admin API Access Token
    shopify_shop_name: your-shop-prefix    # The 'my-shop' part of my-shop.myshopify.com
    # API Version (e.g. "2024-04")
    shopify_last_stable_revision: "2024-04" # Recommended Shopify API version
# ── Security ──────────────────────────────────────────────────────────────────
# API Access Protection
security:
  # List of authorized API keys.
  # Validated via 'X-API-Key' header OR 'Authorization: Bearer <key>' header.
  api_keys:
    - ${APP_API_KEY:-YOUR_SECRET_API_KEY_HERE}

  # IP Whitelisting: List of authorized IP addresses or CIDR blocks.
  # e.g., "127.0.0.1", "192.168.1.0/24". Leave empty to disable.
  authorized_ips: []

# ── CLI Settings ──────────────────────────────────────────────────────────────
# Global settings for CLI commands (bin/cli.php).
cli:
  # Memory limit for all database-heavy CLI operations (e.g. 512M, 1G, 2G).
  # Use ${CLI_MEMORY_LIMIT:-1G} to override via environment variable.
  memory_limit: ${CLI_MEMORY_LIMIT:-1G}
