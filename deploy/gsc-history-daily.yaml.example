# ─────────────────────────────────────────────────────────────────────────────
# apis-hub · GSC Full Historical + Daily Sync Example
# ─────────────────────────────────────────────────────────────────────────────
# This configuration demonstrates how to manage an 18-month history backfill
# while maintaining a fresh daily update pipeline.
#
# Logic:
# 1. We split history into chunks (History workers) to avoid massive jobs.
# 2. We use a daily sync worker for the most recent data (including lag).
# ─────────────────────────────────────────────────────────────────────────────

project: gsc-client-pipeline

database:
  testing:
    driver: pdo_mysql
    host: ${DB_HOST:-127.0.0.1}
    port: 3306
    user: root
    password: YOUR_LOCAL_PASSWORD
    name: ${DB_NAME:-apis_hub_gsc_dev}

  production:
    driver: pdo_mysql
    host: ${PROD_DB_HOST:-host.docker.internal}
    port: 3306
    user: root
    password: ${PROD_DB_PASSWORD:-YOUR_PROD_PASSWORD}
    name: ${PROD_DB_NAME:-apis_hub_gsc_prod}

redis:
  host: ${REDIS_HOST:-127.0.0.1}
  port: ${REDIS_PORT:-6379}

# ── Worker instances ──────────────────────────────────────────────────────────
instances:
  # ---------------------------------------------------------------------------
  # HISTORY BACKFILL (Part 1: 18 months ago to 9 months ago)
  # ---------------------------------------------------------------------------
  - name: gsc-backfill-deep
    # We set a low frequency because historical data is static.
    # It will run once when deployed and then once a month just in case.
    frequency: "0 2 1 * *"
    channel: gsc
    entity: metric
    start_date: "-18 months"
    end_date: "-9 months"

  # ---------------------------------------------------------------------------
  # HISTORY BACKFILL (Part 2: 9 months ago to 3 days ago)
  # ---------------------------------------------------------------------------
  - name: gsc-backfill-recent
    frequency: "0 3 1 * *"
    channel: gsc
    entity: metric
    start_date: "-9 months"
    end_date: "-3 days"

  # ---------------------------------------------------------------------------
  # DAILY CONTINUOUS SYNC
  # ---------------------------------------------------------------------------
  - name: gsc-daily-sync
    # Runs every day at 4:30 AM. 
    # This maintains the "sliding window" of fresh data.
    frequency: "30 4 * * *" 
    channel: gsc
    entity: metric
    # GOLD STANDARD: We use -3 days to yesterday for GSC and Facebook.
    start_date: "-3 days"
    end_date: "yesterday"

# ── Channel credentials ──────────────────────────────────────────────────────
channels:
  google:
    enabled: true                          # Enable Google OAuth
    client_id: ${GOOGLE_CLIENT_ID}
    client_secret: ${GOOGLE_CLIENT_SECRET}
    redirect_uri: ${GOOGLE_REDIRECT_URI}
    refresh_token: ${GOOGLE_REFRESH_TOKEN}
    user_id: ${GOOGLE_USER_EMAIL}          # Principal Google account email
    token_path: ./config/google_tokens.json
    scopes:
      - https://www.googleapis.com/auth/webmasters

  # Google Search Console specific settings
  google_search_console:
    enabled: true                          # Enable Search Console integration
    scope: https://www.googleapis.com/auth/webmasters
    # sites: List of properties you want to track
    sites:
      - url: "sc-domain:yourdomain.com"     # URL prefix OR sc-domain: format for domain properties
        title: "Client Site"                # Friendly display name
        hostname: "yourdomain.com"          # The base domain name
        include_keywords: []                # Optional: Filter for ONLY these keywords
        exclude_keywords: []                # Optional: Skip these keywords
        include_countries: []               # Optional: Filter for ONLY these countries (3-letter codes)
        exclude_countries: []               # Optional: Skip these countries
        include_pages: []                   # Optional: Filter for ONLY these URL paths
        exclude_pages: []                   # Optional: Filter for skiping these URL paths
        target_countries: ["usa"]           # Primary countries for prioritized reporting
        target_keywords: ["brand"]          # Strategic keywords for prioritized reporting
        enabled: true                       # Set to false to temporarily disable this site
    # Cache duration for metrics in seconds (86400 = 24h)
    metrics_cache_ttl: 86400
