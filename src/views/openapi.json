                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AggregationRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Success"
                    }
                }
            }
        },
        "/{channel}/{entity}/{id}": {
            "get": {
                "summary": "Read channeled entity by ID",
                "tags": [
                    "Channeled CRUD"
                ],
                "parameters": [
                    {
                        "name": "channel",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "entity",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    }
                }
            }
        },
        "/{channel}/{entity}": {
            "get": {
                "summary": "List channeled entities",
                "tags": [
                    "Channeled CRUD"
                ],
                "parameters": [
                    {
                        "name": "channel",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "entity",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 10,
                            "enum": [
                                10
                            ]
                        },
                        "description": "Number of records to return. Fixed to 10 in the documentation UI for stability. In production, this can be increased up to 50,000."
                    },
                    {
                        "name": "pagination",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 0
                        },
                        "description": "Page offset (0-indexed). Use this to browse the dataset while the limit is fixed."
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    }
                }
            }
        },
        "/api/monitoring/data": {
            "get": {
                "summary": "Get infrastructure monitoring data",
                "description": "Returns a list of containers (instances) with their configuration and recent job history.",
                "tags": [
                    "Monitoring"
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "instances": {
                                            "type": "array",
                                            "items": {
                                                "type": "object"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/monitoring/jobs/action": {
            "post": {
                "summary": "Execute job administrative actions",
                "description": "Supports actions like 'process' (run now), 'retry' (re-schedule), and 'cancel' (discard).",
                "tags": [
                    "Monitoring"
                ],
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "id",
                                    "action"
                                ],
                                "properties": {
                                    "id": {
                                        "type": "integer",
                                        "description": "numerical Job ID"
                                    },
                                    "action": {
                                        "type": "string",
                                        "enum": [
                                            "process",
                                            "retry",
                                            "cancel"
                                        ]
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Success"
                    },
                    "400": {
                        "description": "Invalid parameters"
                    }
                }
            }
        },
        "/api/compute-kpi": {
            "post": {
                "summary": "Calculate custom cross-platform KPI",
                "description": "Evaluates a dynamic AST containing metric operations, forwarding statistical calculations to the Python Analytics Engine when required.",
                "tags": [
                    "Analytics"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "ast": {
                                        "type": "object",
                                        "description": "The dynamic mathematical Abstract Syntax Tree mapping out the cross-metric KPI."
                                    },
                                    "calculate_regression": {
                                        "type": "boolean",
                                        "description": "Flag to pass the aggregated results through the Python Engine's Linear Regression algorithm."
                                    },
                                    "admin_api_key": {
                                        "type": "string",
                                        "description": "The internal admin key passed by Facade to authorize Python Engine matrix processing."
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Calculation completed successfully"
                    },
                    "400": {
                        "description": "Invalid AST payload"
                    },
                    "500": {
                        "description": "Python Analytics Engine Communication Error"
                    }
                }
            }
        },
        "/api/config-manager/assets": {
            "get": {
                "summary": "Fetch configuration and assets",
                "tags": [
                    "Configuration"
                ],
                "parameters": [
                    {
                        "name": "type",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "refresh",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "0",
                                "1"
                            ]
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    }
                }
            }
        },
        "/api/config-manager/update": {
            "post": {
                "summary": "Update node configuration",
                "tags": [
                    "Configuration"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "type": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Success"
                    }
                }
            }
        },
        "/api/config-manager/validate-tokens": {
            "post": {
                "summary": "Validate API tokens",
                "tags": [
                    "Configuration"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "type": {
                                        "type": "string",
                                        "default": "all"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Success"
                    }
                }
            }
        },
        "/api/config-manager/export": {
            "post": {
                "summary": "Export configurations",
                "tags": [
                    "Configuration"
                ],
                "parameters": [
                    {
                        "name": "X-Config-Token",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success"
                    }
                }
            }
        },
        "/api/config-manager/flush-cache": {
            "post": {
                "summary": "Flush channel aggregation cache",
                "tags": [
                    "Configuration"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
