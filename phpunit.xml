<?xml version="1.0" encoding="UTF-8"?>
<phpunit bootstrap="tests/bootstrap.php"
         colors="true"
         verbose="true"
         stopOnFailure="false">
    <testsuites>
        <testsuite name="Services Tests">
            <directory>tests/Unit/Services</directory>
        </testsuite>
        <testsuite name="Helpers Tests">
            <directory>tests/Unit/Helpers</directory>
        </testsuite>
        <testsuite name="Repositories Tests">
            <directory>tests/Unit/Repositories</directory>
        </testsuite>
        <testsuite name="Controllers Tests">
            <directory>tests/Unit/Controllers</directory>
        </testsuite>
        <testsuite name="Classes Tests">
            <directory>tests/Unit/Classes</directory>
        </testsuite>
        <testsuite name="Commands Tests">
            <directory>tests/Unit/Commands</directory>
        </testsuite>
        <testsuite name="Integration Tests">
            <directory>tests/Integration</directory>
        </testsuite>
        <testsuite name="Core Tests">
            <directory>tests/Unit/Core</directory>
        </testsuite>
    </testsuites>
    <coverage processUncoveredFiles="true">
        <include>
            <directory suffix=".php">src</directory>
        </include>
        <exclude>
            <file>src/Helpers/.php-cs-fixer.dist.php</file>
            <file>src/Repositories/.php-cs-fixer.dist.php</file>
            <file>src/Routes/.php-cs-fixer.dist.php</file>
        </exclude>
    </coverage>

    <php>
        <!-- Path to the YAML config file for tests.
             Leave empty to try config/config.yaml; if absent the suite continues.
               DB:      TEST_DB_DRIVER / TEST_DB_HOST / TEST_DB_PORT / TEST_DB_USER / TEST_DB_PASSWORD / TEST_DB_NAME
               Redis:   REDIS_HOST / REDIS_PORT / REDIS_PASSWORD
               Channels: CHANNELS_CONFIG (JSON blob) or individual GOOGLE_* / FACEBOOK_* env vars -->
        <env name="CONFIG_FILE" value=""/>
        <env name="CONFIG_DIR" value="config"/>
    </php>
</phpunit>